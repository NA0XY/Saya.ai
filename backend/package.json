{
  "name": "saya-ai-backend",
  "version": "1.0.0",
  "description": "Saya.ai autonomous elder care companion backend",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "node --test -r ts-node/register \"tests/**/*.test.ts\"",
    "seed": "ts-node src/data/indianDrugSeed.ts",
    "stt:local": "python voice_services/stt_service.py",
    "stt:health": "node scripts/check-local-stt.mjs",
    "tts:piper:check": "node scripts/check-piper-config.mjs",
    "voice:doctor": "npm run tts:piper:check && npm run stt:health",
    "piper:en": "python -m piper.http_server -m ./voices/en_US-lessac-medium.onnx --host 127.0.0.1 --port 5000",
    "piper:hi": "python -m piper.http_server -m ./voices/hi_IN-pratham-medium.onnx --host 127.0.0.1 --port 5001",
    "piper:test": "node -e \"fetch('http://127.0.0.1:5000',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({text:'hello from piper'})}).then(r=>{if(!r.ok) throw new Error('EN failed'); return r.arrayBuffer();}).then(()=>fetch('http://127.0.0.1:5001',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({text:'namaste dosto'})})).then(r=>{if(!r.ok) throw new Error('HI failed'); return r.arrayBuffer();}).then(()=>console.log('Piper EN+HI OK')).catch(e=>{console.error(e.message);process.exit(1);});\""
  },
  "dependencies": {
    "@google-cloud/vision": "^4.3.3",
    "@supabase/supabase-js": "^2.49.1",
    "axios": "^1.8.4",
    "bcryptjs": "^3.0.2",
    "bull": "^4.16.5",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "groq-sdk": "^0.9.1",
    "helmet": "^8.0.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^4.2.1",
    "twilio": "^6.0.0",
    "uuid": "^14.0.0",
    "winston": "^3.17.0",
    "ws": "^8.18.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.13.13",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.5.14",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.2"
  }
}
