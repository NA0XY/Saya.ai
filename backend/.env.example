PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq
GROQ_API_KEY=your-groq-api-key

# Google Cloud Vision
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json

# AWS (Amazon Polly via Exotel)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=ap-south-1

# Exotel
EXOTEL_SID=your-exotel-sid
EXOTEL_API_KEY=your-exotel-api-key
EXOTEL_API_TOKEN=your-exotel-token
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_CALLER_ID=+91XXXXXXXXXX

# NewsAPI
NEWS_API_KEY=your-newsapi-key

# Provider timeouts
GROQ_TIMEOUT_MS=15000
GOOGLE_VISION_TIMEOUT_MS=15000
EXOTEL_TIMEOUT_MS=10000
POLLY_TIMEOUT_MS=15000
NEWS_TIMEOUT_MS=10000

# Medical fallback APIs
OPENFDA_API_KEY=
OPENFDA_LABEL_URL=https://api.fda.gov/drug/label.json
OPENFDA_TIMEOUT_MS=10000
RXNORM_BASE_URL=https://rxnav.nlm.nih.gov/REST
RXNORM_TIMEOUT_MS=10000

# JWT
JWT_SECRET=your-jwt-secret-minimum-32-chars
JWT_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Call retry config
MAX_CALL_RETRIES=5
RETRY_INTERVAL_MINUTES=3
