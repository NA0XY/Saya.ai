PORT=3001
NODE_ENV=development

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq
GROQ_API_KEY=your-groq-api-key

# Google Cloud Vision
GOOGLE_APPLICATION_CREDENTIALS=./gcp-credentials.json

# Google OAuth
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_OAUTH_REDIRECT_URL=http://localhost:3001/v1/auth/google/callback

# AWS (retained for future use; TTS is now handled by Twilio <Say>)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# Twilio (voice + SMS)
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# GNews API
NEWS_API_KEY=your-gnews-api-key

# Companion voice runtime (English-only v1)
COMPANION_TTS_PROVIDER=piper
COMPANION_STT_PROVIDER=groq_whisper
LOCAL_STT_URL=http://127.0.0.1:7001
LOCAL_STT_TIMEOUT_MS=12000

# Piper CLI (primary TTS)
PIPER_BINARY_PATH=./voice_services/bin/piper.exe
PIPER_MODEL_EN_PATH=./voices/en_US-lessac-medium.onnx
PIPER_CONFIG_EN_PATH=./voices/en_US-lessac-medium.onnx.json

# Optional debug-only Piper HTTP fallback
PIPER_HTTP_DEBUG_ENABLED=false
PIPER_TTS_URL=http://127.0.0.1:5000

# Provider timeouts
GROQ_TIMEOUT_MS=15000
GOOGLE_VISION_TIMEOUT_MS=15000
TWILIO_TIMEOUT_MS=10000
POLLY_TIMEOUT_MS=15000
NEWS_TIMEOUT_MS=10000

# Medical fallback APIs
OPENFDA_API_KEY=
OPENFDA_LABEL_URL=https://api.fda.gov/drug/label.json
OPENFDA_TIMEOUT_MS=10000
RXNORM_BASE_URL=https://rxnav.nlm.nih.gov/REST
RXNORM_TIMEOUT_MS=10000

# JWT
JWT_SECRET=your-jwt-secret-minimum-32-chars
JWT_EXPIRES_IN=7d

# Frontend
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:3001

# File Upload
MAX_FILE_SIZE_MB=10
UPLOAD_DIR=./uploads

# Call retry config
MAX_CALL_RETRIES=5
RETRY_INTERVAL_MINUTES=3
